<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="banawa.isi.java_messagerie.controller.ChatController"
      prefWidth="950" prefHeight="620"
      style="-fx-background-color: #f0f0f0;">

    <!-- ══ Panneau gauche : contacts ══ -->
    <VBox prefWidth="280"
          style="-fx-background-color: #ffffff;
                 -fx-border-color: #e0e0e0;
                 -fx-border-width: 0 1 0 0;">

        <!-- En-tête -->
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: #0d1b2a; -fx-padding: 14 12 14 15;">
            <Circle radius="18" fill="#128c7e"/>
            <Label fx:id="myUsernameLabel" text="You"
                   style="-fx-text-fill: white; -fx-font-size: 15; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="logoutButton" text="déconnexion"
                    onAction="#handleLogout"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #ccffcc;
                           -fx-cursor: hand;
                           -fx-font-size: 12;
                           -fx-border-color: #ccffcc;
                           -fx-border-radius: 10;
                           -fx-background-radius: 10;
                           -fx-padding: 3 10 3 10;"/>
        </HBox>

        <!-- Barre de recherche -->
        <HBox style="-fx-background-color: #f6f6f6; -fx-padding: 8 10 8 10;">
            <TextField fx:id="searchField"
                       promptText="🔍  Recherche contacts..."
                       HBox.hgrow="ALWAYS"
                       onKeyReleased="#handleSearch"
                       style="-fx-background-radius: 20;
                              -fx-border-radius: 20;
                              -fx-border-color: #e0e0e0;
                              -fx-padding: 7 14 7 14;
                              -fx-font-size: 13;
                              -fx-background-color: white;"/>
        </HBox>

        <!-- Boutons filtre -->
        <HBox spacing="6" alignment="CENTER_LEFT"
              style="-fx-padding: 6 10 6 10; -fx-background-color: #fafafa;">

            <Button fx:id="filterAllButton" text="Tous"
                    onAction="#handleFilterAll"
                    style="-fx-background-color: #0d1b2a;
                           -fx-text-fill: white;
                           -fx-background-radius: 12;
                           -fx-padding: 4 10 4 10;
                           -fx-font-size: 11;
                           -fx-cursor: hand;"/>

            <Button fx:id="filterOnlineButton" text="● en ligne"
                    onAction="#handleFilterOnline"
                    style="-fx-background-color: #e8f5e9;
                           -fx-text-fill: #25d366;
                           -fx-background-radius: 12;
                           -fx-padding: 4 10 4 10;
                           -fx-font-size: 11;
                           -fx-cursor: hand;"/>

            <Button fx:id="filterOfflineButton" text="● hors ligne"
                    onAction="#handleFilterOffline"
                    style="-fx-background-color: #f5f5f5;
                           -fx-text-fill: #888;
                           -fx-background-radius: 12;
                           -fx-padding: 4 10 4 10;
                           -fx-font-size: 11;
                           -fx-cursor: hand;"/>
        </HBox>

        <Separator/>

        <!-- Liste contacts -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox fx:id="contactListVBox" spacing="0"
                  style="-fx-background-color: white;"/>
        </ScrollPane>
    </VBox>

    <!-- ══ Panneau droit : chat ══ -->
    <VBox HBox.hgrow="ALWAYS"
          style="-fx-background-color: #ece5dd;">

        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #0d1b2a; -fx-padding: 12 15 12 15;">
            <StackPane>
                <Circle radius="20" fill="#128c7e"/>
                <Label fx:id="chatPartnerInitialLabel" text="?"
                       style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16;"/>
                <Circle fx:id="chatPartnerStatusDot" radius="7" fill="#bdbdbd"
                        StackPane.alignment="BOTTOM_RIGHT"/>
            </StackPane>
            <VBox spacing="2">
                <Label fx:id="chatPartnerNameLabel" text="Selectionner un contact"
                       style="-fx-text-fill: white; -fx-font-size: 15; -fx-font-weight: bold;"/>
                <Label fx:id="chatPartnerStatusLabel" text=""
                       style="-fx-text-fill: #b2dfdb; -fx-font-size: 11;"/>
            </VBox>
        </HBox>

        <ScrollPane fx:id="chatPane" VBox.vgrow="ALWAYS" fitToWidth="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox fx:id="scrollbodyChatVBox" spacing="5"
                  style="-fx-padding: 12 8 12 8; -fx-background-color: #ece5dd;"/>
        </ScrollPane>

        <HBox spacing="10"
              style="-fx-background-color: #f0f0f0; -fx-padding: 10 12 10 12;"
              alignment="CENTER">
            <TextField fx:id="inputMessageField"
                       promptText="Tape un message..."
                       HBox.hgrow="ALWAYS"
                       onAction="#handleSend"
                       style="-fx-background-radius: 25;
                              -fx-border-radius: 25;
                              -fx-border-color: #e0e0e0;
                              -fx-padding: 10 18 10 18;
                              -fx-font-size: 14;
                              -fx-background-color: white;"/>
            <Button fx:id="sendButton" text="Envoie"
                    onAction="#handleSend"
                    style="-fx-background-color: #0d1b2a;
                           -fx-text-fill: white;
                           -fx-background-radius: 25;
                           -fx-padding: 10 22 10 22;
                           -fx-font-weight: bold;
                           -fx-font-size: 13;
                           -fx-cursor: hand;"/>
        </HBox>
    </VBox>

</HBox>
